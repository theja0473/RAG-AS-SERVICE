# OpenAgentRAG Configuration
# Copy this file to .env and configure with your values

# ===== Ollama Configuration =====
OLLAMA_BASE_URL=http://ollama:11434
# For local development (non-Docker): http://localhost:11434

# ===== ChromaDB Configuration =====
CHROMA_HOST=chromadb
CHROMA_PORT=8000
# For local development (non-Docker): localhost

# ===== Model Configuration =====
# Embedding model for vector search
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Alternate embedding options:
# - sentence-transformers/all-mpnet-base-v2 (higher quality, slower)
# - sentence-transformers/multi-qa-MiniLM-L6-cos-v1 (optimized for Q&A)

# LLM model for generation (must be available in Ollama)
LLM_MODEL=llama3
# Alternate LLM options:
# - mistral (faster, less resource-intensive)
# - llama3:70b (higher quality, requires more resources)
# - mixtral (good balance of speed and quality)

# ===== Neo4j Knowledge Graph =====
NEO4J_URI=bolt://neo4j:7687
# For local development (non-Docker): bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=openagentrag
# Enable/disable Graph RAG (knowledge graph enrichment)
GRAPH_RAG_ENABLED=true

# ===== RAG Configuration =====
# Chunking parameters
CHUNK_SIZE=512
CHUNK_OVERLAP=50
# Recommended ranges:
# - CHUNK_SIZE: 256-1024 (smaller for precise retrieval, larger for context)
# - CHUNK_OVERLAP: 10-20% of CHUNK_SIZE

# Retrieval parameters
TOP_K_RETRIEVAL=5
SIMILARITY_THRESHOLD=0.7

# ===== Agent Configuration =====
# CrewAI settings
AGENT_MAX_ITERATIONS=10
AGENT_VERBOSE=true

# Query expansion settings
ENABLE_QUERY_EXPANSION=true
NUM_QUERY_VARIATIONS=2

# ===== Backend API Configuration =====
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
LOG_LEVEL=INFO

# ===== Frontend Configuration =====
NEXT_PUBLIC_API_URL=http://localhost:8000

# ===== Data Persistence =====
# Local directories for data storage
DATA_DIR=/app/data
UPLOAD_DIR=/app/data/uploads
KB_DIR=/app/data/knowledge_base

# ===== Optional: Advanced Settings =====
# Enable evaluation metrics collection
ENABLE_EVALUATION=false

# Enable feedback loop for self-improvement
ENABLE_FEEDBACK_LOOP=false

# Cache settings
ENABLE_QUERY_CACHE=true
CACHE_TTL_SECONDS=3600

# Rate limiting
ENABLE_RATE_LIMITING=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
